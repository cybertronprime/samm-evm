# Private Key (required for all networks)
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# API Server Configuration
PORT=3000
DEPLOYMENT_FILE=production-risechain-1770744587343.json

# RiseChain Testnet Configuration  
RISECHAIN_RPC_URL=https://testnet.riselabs.xyz/http

# Sepolia Testnet Configuration
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
# Alternative Sepolia RPC URLs (choose one)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# SEPOLIA_RPC_URL=https://sepolia.gateway.tenderly.co

# Monad Testnet Configuration
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
# Alternative Monad Testnet RPC URLs
# MONAD_RPC_URL=https://monad-testnet-rpc.alt-provider.com

# Gas Reporting (optional)
REPORT_GAS=false

# Block Explorer API Keys (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
MONAD_API_KEY=your_monad_explorer_api_key_here
RISECHAIN_API_KEY=your_risechain_explorer_api_key_here

# Deployment Options
AUTO_INITIALIZE=false
INITIAL_LIQUIDITY_A=10000
INITIAL_LIQUIDITY_B=10000
TRADE_FEE_NUMERATOR=25
TRADE_FEE_DENOMINATOR=10000
OWNER_FEE_NUMERATOR=10
OWNER_FEE_DENOMINATOR=10000

# ============================================================
# Partner Integration Settings
# ============================================================

# Uniswap Integration (Sepolia)
UNISWAP_API_KEY=your_uniswap_api_key
UNISWAP_ROUTER_ADDRESS=0xE592427A0AEce92De3Edee1F18E0157C05861564
UNISWAP_QUOTER_ADDRESS=0xEd1f6473345F45b75F8179591dd5bA1888cf2FB3
SAMM_ROUTER_ADDRESS=

# Chainlink Integration (Sepolia)
CHAINLINK_VRF_SUBSCRIPTION_ID=your_subscription_id

# Arc Integration
ARC_RPC_URL=https://testnet-rpc.arc.network
ARC_CHAIN_ID=32659
NANOPAYMENT_ARBITRAGEUR_ADDRESS=
SAMM_FACTORY_ADDRESS=

# Agent Configuration
ARBITRAGE_THRESHOLD=0.005
AGENT_INTERVAL_MS=30000
