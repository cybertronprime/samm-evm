{
  "name": "samm-evm",
  "version": "2.0.0",
  "description": "SAMM — Sharded Automated Market Maker for EVM chains",
  "main": "api-server.js",
  "scripts": {
    "start": "node api-server.js",
    "compile": "hardhat compile",
    "clean": "hardhat clean && rm -rf cache artifacts",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/**/*.test.js",
    "test:offchain": "mocha test/offchain/**/*.test.js",
    "node": "hardhat node",
    "deploy:risechain": "hardhat run scripts/deploy-production-risechain.js --network risechain",
    "deploy:risechain:v2": "hardhat run scripts/deploy-production-risechain-v2.js --network risechain",
    "deploy:router": "hardhat run scripts/deploy-crosspool-router-risechain.js --network risechain",
    "deploy:faucet": "hardhat run scripts/deploy-faucet-risechain.js --network risechain",
    "test:swap-matrix": "hardhat run scripts/validate-risechain-swap-matrix.js --network risechain",
    "test:e2e": "hardhat run scripts/comprehensive-e2e-test-risechain.js --network risechain",
    "bench:batched": "hardhat run scripts/bench-batched.js --network risechain",
    "bench:tps": "hardhat run scripts/bench-sustained-tps.js --network risechain",
    "verify:apis": "node scripts/verify-all-apis.js"
  },
  "keywords": [
    "SAMM",
    "AMM",
    "DeFi",
    "Solidity",
    "EVM",
    "Token Swap"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.3.0",
    "ethers": "^6.4.0",
    "fast-check": "^4.3.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "mocha": "^10.0.0",
    "solidity-coverage": "^0.8.0",
    "typechain": "^8.3.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "axios": "^1.13.2",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^5.1.0",
    "supertest": "^7.1.4"
  }
}
